{
  "expo": {
    "name": "BDG Motor Show",
    "slug": "bdg-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "bdg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.biancolastudio.bdg",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "L'app utilise votre position pour la carte interactive du circuit.",
        "NSCameraUsageDescription": "L'app utilise la camera pour scanner les QR codes des billets."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyB_9aJIp41z0G-6x4lHmj8_w0L-1wwvu7w"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.biancolastudio.bdg",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB_9aJIp41z0G-6x4lHmj8_w0L-1wwvu7w"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#D91E28"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "L'app utilise votre position pour la carte interactive."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "L'app utilise la camera pour scanner les QR codes."
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./src/assets/icon.png"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
